      "day-a@example.jp",
      "day-b@example.jp",
      "day-c@example.jp",
      "day-d@example.jp",
      "care-support@example.jp"
    ]
  },

  "tagOwners": {
    "tag:nas-core": ["group:admins"]
  },

  "autoApprovers": {
