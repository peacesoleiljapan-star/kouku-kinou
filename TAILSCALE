      "day-b@example.jp",
      "day-c@example.jp",
      "day-d@example.jp"
    ],
    "group:company": ["company@example.jp"],
    "group:care-support": ["care-support@example.jp"],
    "group:cafe": ["cafe@example.jp"],

    "group:care-all": [
