# Tailscale Serve で HTTPS 終端する前提の初期設定です。
# 実運用前に管理者用パスワードと配布 URL を必ず見直してください。
KOUKU_KINOU_AUTH_MODE=tailscale-or-password
KOUKU_KINOU_PASSWORD=change-this-admin-password
KOUKU_KINOU_SESSION_TTL_MINUTES=120
KOUKU_KINOU_SECURE_COOKIE=1
# 通常は空欄のままで構いません。追加の IP 制限が必要なときだけ設定します。
KOUKU_KINOU_ALLOWED_NETWORKS=
# X-Forwarded-For を使った IP 制限が必要な場合だけ 1 にします。
KOUKU_KINOU_TRUST_PROXY=0